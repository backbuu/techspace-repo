# Copy to backend/.env and fill in values.
# Frontend vars live in frontend/.env.local (prefixed with VITE_).
# Never commit real keys — .env files are gitignored.

# ── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# Server-side only — bypasses RLS, never expose to the frontend
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth roles ──────────────────────────────────────────────────
# Set these as custom claims in Supabase Auth or via a trigger
# AUTHOR_ROLE=author
# READER_ROLE=reader

# ── Phase 2: AI (semantic search + writing assistant) ───────────
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=

# ── Observability (Phase 2) ─────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=techspace

# ── Nutanix Lab ─────────────────────────────────────────────────
NUTANIX_PC_IP=
NUTANIX_PC_PORT=9440
NUTANIX_USER=
NUTANIX_PASSWORD=

# ── Test credentials (never commit real values) ─────────────────
TEST_AUTHOR_EMAIL=
TEST_AUTHOR_PASSWORD=
TEST_READER_EMAIL=
TEST_READER_PASSWORD=

# ── Frontend (frontend/.env.local) ──────────────────────────────
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=
# VITE_API_URL=http://localhost:8000
